<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Status</title>
</head>
<body>
        <% if (isLoggedIn) { %>
        <h1>Welcome back, <%= username %></h1>
        <% } else { %>
        <h1>Please login</h1>
        <% } %>
</body>
</html>