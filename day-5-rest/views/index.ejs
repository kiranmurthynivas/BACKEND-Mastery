<!DOCTYPE html>
<html>
<head>
  <title>All Posts</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <h1>All Posts</h1>

  <a href="/posts/new">Create New Post</a>

  <% for (let post of posts) { %>
    <div class="post">
      <h3>@<%= post.username %></h3>
      <p><%= post.content %></p>
      <a href="/posts/<%= post.id %>">View Post</a>
      <a href="/posts/<%= post.id %>/edit">Edit Post</a>
    </div>
  <% } %>
</body>
</html>