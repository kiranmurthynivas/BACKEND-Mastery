<!DOCTYPE html>
<html>
<head>
  <title>Show Post</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <h1>Post Details</h1>

  <div class="post">
    <h3>@<%= post.username %></h3>
    <p><%= post.content %></p>
    <p><strong>ID:</strong> <%= post.id %></p>
  </div>

  <a href="/posts">Back to all posts</a>
</body>
</html>